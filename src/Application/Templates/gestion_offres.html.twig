<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>Gestion des offres</title>

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet"/>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

		<style>
			body {
				font-family: "Poppins", sans-serif;
				background-color: #1a1a1a;
				color: white;
				padding: 30px;
			}

			h2 {
				font-weight: 600;
				margin-bottom: 30px;
				color: #72b1d5;
			}

			/* Style des inputs mode sombre */
			.form-control-dark {
				background-color: #121212 !important;
				border: 1px solid #333 !important;
				color: #ccc !important;
				font-size: 0.9rem;
			}

			.form-control-dark:focus {
				border-color: #72b1d5 !important;
				box-shadow: none;
			}

			/* Tableau personnalisé */
			.table-custom {
				background-color: #212121 !important;
				border: 1px solid #333;
			}

			.table-custom th {
				background-color: #2c2c2c !important;
				color: #888 !important;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 1px;
				border-bottom: 2px solid #333;
			}

			.table-custom td {
				color: #ccc;
				vertical-align: middle;
				border-bottom: 1px solid #333;
			}

			/* Boutons */
			.btn-add-custom {
				background-color: #4a4a4a;
				color: white;
				border: none;
				transition: 0.3s;
			}

			.btn-add-custom:hover {
				background-color: #72b1d5;
				color: white;
			}

			.btn-delete,
			.btn-edit {
				background: none;
				border: none;
				opacity: 0.6;
				transition: 0.3s;
				font-size: 1.1rem;
			}

			.btn-delete:hover,
			.btn-edit:hover {
				opacity: 1;
				transform: scale(1.2);
			}
			.glass {
				background: var(--glass);
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 15px;
			}
			input::placeholder {
				color: white !important;
			}
		</style>
	</head>
	<body>
		<div class="container-fluid">
			<div class="d-flex justify-content-between align-items-center px-lg-5">
				<h2>Gestion des Offres</h2>
				<a href="/" class="glass d-inline-flex align-items-center p-2 px-3 text-decoration-none text-white mb-auto">
					<img src="./image/ReadyToWork.png" alt="Logo" height="35" class="me-2"/>
					<span class="fw-bold">ReadyToWork</span>
				</a>
			</div>
			<div class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow-sm border border-secondary border-opacity-25">
				<div class="col-auto">
					<button class="btn btn-add-custom px-4 fw-bold" id="add-student-btn">
						+
					</button>
				</div>
				<div class="col">
					<input type="text" id="input-id" class="form-control form-control-dark" placeholder="ID"/>
				</div>
				<div class="col">
					<input type="text" id="input-fname" class="form-control form-control-dark" placeholder="Nom entreprise"/>
				</div>
				<div class="col">
					<input type="text" id="input-lname" class="form-control form-control-dark" placeholder="Domaine"/>
				</div>
				<div class="col">
					<input type="text" id="input-user" class="form-control form-control-dark" placeholder="Lieux"/>
				</div>
				<div class="col">
					<input type="email" id="input-email" class="form-control form-control-dark" placeholder="E-mail"/>
				</div>
				<div class="col">
					<input type="text" id="input-description" class="form-control form-control-dark" placeholder="Description"/>
				</div>
				<div class="col">
					<input type="text" id="input-age" class="form-control form-control-dark" placeholder="Duree stage"/>
				</div>
			</div>

			<div class="table-responsive rounded">
				<table class="table table-dark table-hover mb-0 table-custom">
					<thead>
						<tr>
							<th class="text-center">Actions</th>
							<th>ID</th>
							<th>Name</th>
							<th>Domain</th>
							<th>Username</th>
							<th>E-mail</th>
							<th>Description</th>
							<th>Time</th>
						</tr>
					</thead>
					<tbody id="table-body">
						{% for gestion_offre in gestion_offres %}
							<tr>
								<td class="text-center">
									<button class="btn-delete btn-supprimer">🗑️</button>
									<button class="btn-edit btn-modifier">✏️</button>
								</td>
								<td>{{ gestion_offre.id }}</td>
								<td>{{ gestion_offre.nom }}</td>
								<td>{{ gestion_offre.domaine }}</td>
								<td>{{ gestion_offre.lieu }}</td>
								<td>{{ gestion_offre.email }}</td>
								<td>{{ gestion_offre.description }}</td>
								<td>{{ gestion_offre.duree }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
		<div class="mt-5">
			<nav aria-label="Pagination">
				<ul class="pagination mb-0 justify-content-center">
					<li class="page-item">
						<a class="page-link" href="?page={{ page - 1 }}">
							&laquo; Page précédente
						</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=1">1</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=2">2</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=3">3</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=4">4</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=5">5</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=6">6</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=7">7</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=8">8</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=9">9</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=10">10</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page={{ page + 1 }}">
							Page suivante &raquo;
						</a>
					</li>
				</li>
			</ul>
		</nav>
	</body>
</html>
