{% extends 'base2.html.twig' %}
{% block title %}Gestion des Offres
{% endblock %}
{% block heading %}Gestion des Offres
{% endblock %}
{% block content %}
	<form method="POST" action="{{ url_for('ajout-offres') }}" class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow-sm border border-secondary border-opacity-25">
		<div class="col-auto">
			<button type="submit" class="btn btn-add-custom px-4 fw-bold" id="add-student-btn">
				+
			</button>
		</div>
		<div class="col">
			<input type="text" name="nom" id="input-fname" class="form-control form-control-dark" placeholder="Nom entreprise" required/>
		</div>
		<div class="col">
			<input type="text" name="domaine" id="input-lname" class="form-control form-control-dark" placeholder="Domaine" required/>
		</div>
		<div class="col">
			<input type="text" name="lieu" id="input-user" class="form-control form-control-dark" placeholder="Lieux" required/>
		</div>
		<div class="col">
			<input type="email" name="email" id="input-email" class="form-control form-control-dark" placeholder="E-mail" required/>
		</div>
		<div class="col">
			<input type="text" name="description" id="input-description" class="form-control form-control-dark" placeholder="Description" required/>
		</div>
		<div class="col">
			<input type="text" name="niveau" id="input-niveau" class="form-control form-control-dark" placeholder="Niveau" required/>
		</div>
		<div class="col">
			<input type="text" name="salaire" id="input-salaire" class="form-control form-control-dark" placeholder="Salaire" required/>
		</div>
		<div class="col">
			<input type="text" name="duree" id="input-offres" class="form-control form-control-dark" placeholder="Duree stage" required/>
		</div>
	</form>

	<div class="table-responsive rounded">
		<table class="table table-dark table-hover mb-0 table-custom">
			<thead>
				<tr>
					<th class="text-center">Actions</th>
					<th>ID</th>
					<th>Nom</th>
					<th>Domaine</th>
					<th>Lieux</th>
					<th>E-mail</th>
					<th>Description</th>
					<th>Niveau</th>
					<th>Salaire/Mois</th>
					<th>Duree</th>
				</tr>
			</thead>
			<tbody id="table-body">
				{% for gestion_offre in gestion_offres %}
					<tr>
						<td class="text-center">
							<form method="POST" action="{{ url_for('supprimer-offres', { 'id': gestion_offre.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer cette offre ?')">
								<button type="submit" class="btn-delete">🗑️</button>
							</form>
							<a href="{{ url_for('modifier-offres', { 'id': gestion_offre.id }) }}" class="btn-edit">✏️</a>
						</td>
						<td>{{ gestion_offre.id }}</td>
						<td>{{ gestion_offre.nom }}</td>
						<td>{{ gestion_offre.domaine }}</td>
						<td>{{ gestion_offre.lieu }}</td>
						<td>{{ gestion_offre.email }}</td>
						<td>{{ gestion_offre.description }}</td>
						<td>{{ gestion_offre.niveau }}</td>
						<td>{{ gestion_offre.salaire }}</td>
						<td>{{ gestion_offre.duree }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		{% if totalPages > 1 %}
			<nav class="mt-3">
				<ul class="pagination justify-content-center">

					<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_offres', {'page': page - 1}) }}">&laquo; Précédent</a>
					</li>

					{% for p in 1..totalPages %}
						<li class="page-item {% if p == page %}active{% endif %}">
							<a class="page-link" href="{{ url_for('gestion_offres', {'page': p}) }}">{{ p }}</a>
						</li>
					{% endfor %}

					<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_offres', {'page': page + 1}) }}">Suivant &raquo;</a>
					</li>
				</ul>
			</nav>
		{% endif %}
	</div>
{% endblock %}
