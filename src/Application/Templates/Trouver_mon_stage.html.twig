{% extends 'base.html.twig' %}

{% block title %}Stage-
{% endblock %}

{% block content %}
	<style>
		.sidebar-filtres {
			background: rgba(255, 255, 255, 0.9);
			border-radius: 10px;
			padding: 20px;
			color: black;
			height: fit-content;
		}
		.sidebar-filtres legend {
			font-size: 1.1rem;
			font-weight: bold;
			margin-top: 15px;
			border-bottom: 2px solid #ddd;
		}
		.filter-scroll {
			max-height: 200px;
			overflow-y: auto;
			padding-right: 5px;
		}
		.offres-img {
			width: 100%;
			max-width: 300px;
			border-radius: 8px;
			transition: 0.3s;
		}
		.offres-img:hover {
			transform: scale(1.03);
		}
		h2 {
			-webkit-text-stroke-width: 2px;
			-webkit-text-stroke-color: rgb(26, 189, 230);
		}
		.offre-card {
			background: rgba(255, 255, 255, 0.15);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, 0.3);
			border-radius: 15px;
		}
	</style>

	<main class="container my-5">
		<div class="row g-4">
			<aside class="col-lg-3">
				<div class="sidebar-filtres shadow">
					<h4 class="fw-bold mb-3">Filtres</h4>

					<legend>Région :</legend>
					<div class="filter-scroll">
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="r1" checked/>
							<label class="form-check-label" for="r1">Grand-est</label>
						</div>
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="r2"/>
							<label class="form-check-label" for="r2">Nouvelle-aquitaine</label>
						</div>
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="r3"/>
							<label class="form-check-label" for="r3">Bretagne</label>
						</div>
					</div>

					<legend>Salaire :</legend>
					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="s1"/>
						<label class="form-check-label" for="s1">500€</label>
					</div>
					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="s2"/>
						<label class="form-check-label" for="s2">1000€</label>
					</div>

					<legend>Mode :</legend>
					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="m1" checked/>
						<label class="form-check-label" for="m1">Télétravail</label>
					</div>

					<legend>Domaine :</legend>
					<select class="form-select mt-2">
						<option>Informatique</option>
						<option>Marketing</option>
						<option>Vente</option>
					</select>
				</div>
			</aside>

			<section class="col-lg-9 text-center bg-white bg-opacity-10 rounded p-4 shadow">
				<h2 class="mb-4 fw-bold">Offres</h2>
				<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 justify-content-center">
					{% for stage in stages %}
						<div class="col-md-3">
							<div class="offre-card p-4 text-white">
								<div class="fw-bold fs-5 mb-2">{{ stage.nom }}</div>
								<div class="mb-2">{{ stage.domaine }}</div>
								<div>
									<span class="text-danger">
										<i class="bi bi-geo-alt-fill me-1"></i>
									</span>
									{{ stage.lieu }}</div>
								<div>
									<i class="bi bi-envelope-fill"></i>
									{{ stage.email }}</div>
								<div>
									<span style="color: #4f9de6">
										<i class="bi bi-stopwatch-fill"></i>
									</span>
									{{ stage.duree }}
									|<span style="color: #9a5044">
										<i class="bi bi-briefcase-fill"></i>
									</span>
									{{ stage.niveau }}
									|<span style="color: #35a731">
										<i class="bi bi-currency-exchange"></i>
									</span>
									{{ stage.salaire }}</div>
								<div class="mt-2">{{ stage.description }}</div>
								<a href="{{ url_for('postule', {'id': stage.id}) }}" class="btn btn-primary mt-2" role="button" aria-pressed="true">Postule</a>
								<form method="POST" action="{{ url_for('ajouter-souhait', {'id': stage.id}) }}" style="display:inline">
									<button type="submit" class="btn btn-primary mt-2">Enregistre</button>
								</form>
							</div>
						</div>
					{% endfor %}
				</div>
				{% if totalPages > 1 %}
					<nav class="mt-3">
						<ul class="pagination justify-content-center">

							<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
								<a class="page-link" href="{{ url_for('stage', {'page': page - 1}) }}">&laquo; Précédent</a>
							</li>

							{% for p in 1..totalPages %}
								<li class="page-item {% if p == page %}active{% endif %}">
									<a class="page-link" href="{{ url_for('stage', {'page': p}) }}">{{ p }}</a>
								</li>
							{% endfor %}

							<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
								<a class="page-link" href="{{ url_for('stage', {'page': page + 1}) }}">Suivant &raquo;</a>
							</li>

						</ul>
					</nav>
				{% endif %}
			</section>
		</div>
	</main>
{% endblock %}
