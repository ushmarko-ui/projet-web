{% extends 'base.html.twig' %}

{% block title %}Stage-
{% endblock %}

{% block content %}
	<style>
		.sidebar-filtres {
			background: rgba(255, 255, 255, 0.9);
			border-radius: 10px;
			padding: 20px;
			color: black;
			height: fit-content;
		}
		.sidebar-filtres legend {
			font-size: 1.1rem;
			font-weight: bold;
			margin-top: 15px;
			border-bottom: 2px solid #ddd;
		}
		.filter-scroll {
			max-height: 200px;
			overflow-y: auto;
			padding-right: 5px;
		}
		.offres-img {
			width: 100%;
			max-width: 300px;
			border-radius: 8px;
			transition: 0.3s;
		}
		.offres-img:hover {
			transform: scale(1.03);
		}
		h2 {
			-webkit-text-stroke-width: 2px;
			-webkit-text-stroke-color: rgb(26, 189, 230);
		}
		.offre-card {
			background: rgba(255, 255, 255, 0.15);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, 0.3);
			border-radius: 15px;
		}
	</style>

	<main class="container my-5">
		<div class="row g-4">
			<aside class="col-lg-3">
				<div class="sidebar-filtres shadow">
					<h4 class="fw-bold mb-3">Filtres</h4>

					<legend>Région :</legend>
					<div class="filter-scroll">
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="r1" checked/>
							<label class="form-check-label" for="r1">Grand-est</label>
						</div>
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="r2"/>
							<label class="form-check-label" for="r2">Nouvelle-aquitaine</label>
						</div>
						<div class="form-check">
							<input class="form-check-input" type="checkbox" id="r3"/>
							<label class="form-check-label" for="r3">Bretagne</label>
						</div>
					</div>

					<legend>Salaire :</legend>
					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="s1"/>
						<label class="form-check-label" for="s1">500€</label>
					</div>
					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="s2"/>
						<label class="form-check-label" for="s2">1000€</label>
					</div>

					<legend>Mode :</legend>
					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="m1" checked/>
						<label class="form-check-label" for="m1">Télétravail</label>
					</div>

					<legend>Domaine :</legend>
					<select class="form-select mt-2">
						<option>Informatique</option>
						<option>Marketing</option>
						<option>Vente</option>
					</select>
				</div>
			</aside>

			<section class="col-lg-9 text-center bg-white bg-opacity-10 rounded p-4 shadow">
				<h2 class="mb-4 fw-bold">Offres</h2>
				<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 justify-content-center">
					{% for offre in offres %}
						<div class="col-md-3">
							<div class="offre-card p-4 text-white">
								<div class="fw-bold fs-5 mb-2">{{ offre.nom }}</div>
								<div class="mb-2">{{ offre.domaine }}</div>
								<div>📍
									{{ offre.lieu }}</div>
								<div>✉️
									{{ offre.email }}</div>
								<div>⏱️
									{{ offre.duree }}</div>
								<div class="mt-2">{{ offre.description }}</div>
								<a href="/postule" class="btn btn-primary mt-2" role="button" aria-pressed="true">Postule</a>
								<a href="/souhait" class="btn btn-primary mt-2" role="button" aria-pressed="true">Enregistre</a>
								<a href="/souhait" class="btn btn-primary mt-2" role="button" aria-pressed="true">Statistique</a>
							</div>
						</div>
					{% endfor %}
				</div>

				<div class="mt-5">
					<nav aria-label="Pagination">
						<ul class="pagination mb-0 justify-content-center">
							<li class="page-item">
								<a class="page-link" href="?page=1">
									&laquo; Page précédente
								</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=1">1</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=2">2</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=3">3</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=4">4</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=5">5</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=6">6</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=7">7</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=8">8</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=9">9</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=10">10</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="?page=2">
									Page suivante &raquo;
								</a>
							</li>
						</ul>
					</nav>
				</div>
			</section>
		</div>
	</main>
{% endblock %}
