{% extends 'base2.html.twig' %}
{% block title %}Gestion des Etudiants
{% endblock %}
{% block heading %}Gestion des Etudiants
{% endblock %}
{% block content %}

	<form method="POST" action="{{ url_for('ajout-etudiants') }}" class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow-sm border border-secondary border-opacity-25">
		<div class="col-auto">
			<button type="submit" class="btn btn-add-custom px-4 fw-bold">+</button>
		</div>
		<div class="col">
			<input type="text" name="prenom" class="form-control form-control-dark" placeholder="Prénom"/>
		</div>
		<div class="col">
			<input type="text" name="nom" class="form-control form-control-dark" placeholder="Nom"/>
		</div>
		<div class="col">
			<input type="email" name="email" class="form-control form-control-dark" placeholder="E-mail"/>
		</div>
		<div class="col">
			<input type="number" name="age" class="form-control form-control-dark" placeholder="Age"/>
		</div>
	</form>

	<div class="table-responsive rounded">
		<table class="table table-dark table-hover mb-0 table-custom">
			<thead>
				<tr>
					<th class="text-center">Actions</th>
					<th>ID</th>
					<th>Prénom</th>
					<th>Nom</th>
					<th>E-mail</th>
					<th>Age</th>
				</tr>
			</thead>
			<tbody>
				{% for gestion_etudiant in gestion_etudiants %}
					<tr>
						<td class="text-center">
							<form method="POST" action="{{ url_for('supprimer-etudiants', { 'id': gestion_etudiant.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer ce compte étudiant ?')">
								<button type="submit" class="btn-delete">🗑️</button>
							</form>
							<a href="{{ url_for('modifier-etudiants', { 'id': gestion_etudiant.id }) }}" class="btn-edit">✏️</a>
						</td>
						<td>{{ gestion_etudiant.id }}</td>
						<td>{{ gestion_etudiant.prenom }}</td>
						<td>{{ gestion_etudiant.nom }}</td>
						<td>{{ gestion_etudiant.email }}</td>
						<td>{{ gestion_etudiant.age }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		{% if totalPages > 1 %}
			<nav class="mt-3">
				<ul class="pagination justify-content-center">

					<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_etudiants', {'page': page - 1}) }}">&laquo; Précédent</a>
					</li>

					{% for p in 1..totalPages %}
						<li class="page-item {% if p == page %}active{% endif %}">
							<a class="page-link" href="{{ url_for('gestion_etudiants', {'page': p}) }}">{{ p }}</a>
						</li>
					{% endfor %}

					<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_etudiants', {'page': page + 1}) }}">Suivant &raquo;</a>
					</li>
				</ul>
			</nav>
		{% endif %}
	</div>
{% endblock %}
