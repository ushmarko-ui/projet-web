<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>Gestion des Étudiants</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet"/>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		<style>
			body {
				font-family: "Poppins", sans-serif;
				background-color: #1a1a1a;
				color: white;
				padding: 30px;
			}
			h2 {
				font-weight: 600;
				margin-bottom: 30px;
				color: #72b1d5;
			}
			.form-control-dark {
				background-color: #121212 !important;
				border: 1px solid #333 !important;
				color: #ccc !important;
				font-size: 0.9rem;
			}
			.form-control-dark:focus {
				border-color: #72b1d5 !important;
				box-shadow: none;
			}
			.table-custom th {
				background-color: #2c2c2c !important;
				color: #888 !important;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 1px;
				border-bottom: 2px solid #333;
			}
			.table-custom td {
				color: #ccc;
				vertical-align: middle;
				border-bottom: 1px solid #333;
			}
			.btn-add-custom {
				background-color: #4a4a4a;
				color: white;
				border: none;
				transition: 0.3s;
			}
			.btn-add-custom:hover {
				background-color: #72b1d5;
				color: white;
			}
			.btn-delete,
			.btn-edit {
				background: none;
				border: none;
				opacity: 0.6;
				transition: 0.3s;
				font-size: 1.1rem;
				text-decoration: none;
			}
			.btn-delete:hover,
			.btn-edit:hover {
				opacity: 1;
				transform: scale(1.2);
			}
			.glass {
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 15px;
			}
			input::placeholder {
				color: white !important;
			}
		</style>
	</head>
	<body>
		<div class="container-fluid">
			<div class="d-flex justify-content-between align-items-center px-lg-5">
				<h2>Gestion des Étudiants</h2>
				<a href="/" class="glass d-inline-flex align-items-center p-2 px-3 text-decoration-none text-white mb-auto">
					<span class="fw-bold">ReadyToWork</span>
				</a>
			</div>

			<form method="POST" action="/gestion_etudiants/ajouter" class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow-sm border border-secondary border-opacity-25">
				<div class="col-auto">
					<button type="submit" class="btn btn-add-custom px-4 fw-bold">+</button>
				</div>
				<div class="col">
					<input type="text" name="prenom" class="form-control form-control-dark" placeholder="Prénom"/>
				</div>
				<div class="col">
					<input type="text" name="nom" class="form-control form-control-dark" placeholder="Nom"/>
				</div>
				<div class="col">
					<input type="email" name="email" class="form-control form-control-dark" placeholder="E-mail"/>
				</div>
				<div class="col">
					<input type="number" name="age" class="form-control form-control-dark" placeholder="Age"/>
				</div>
			</form>

			<div class="table-responsive rounded">
				<table class="table table-dark table-hover mb-0 table-custom">
					<thead>
						<tr>
							<th class="text-center">Actions</th>
							<th>ID</th>
							<th>Prénom</th>
							<th>Nom</th>
							<th>E-mail</th>
							<th>Age</th>
						</tr>
					</thead>
					<tbody>
						{% for gestion_etudiant in gestion_etudiants %}
							<tr>
								<td class="text-center">
									<form method="POST" action="/gestion_etudiants/supprimer/{{ gestion_etudiant.id }}" style="display:inline" onsubmit="return confirm('Supprimer cet étudiant ?')">
										<button type="submit" class="btn-delete">🗑️</button>
									</form>
									<a href="/gestion_etudiants/modifier/{{ gestion_etudiant.id }}" class="btn-edit">✏️</a>
								</td>
								<td>{{ gestion_etudiant.id }}</td>
								<td>{{ gestion_etudiant.prenom }}</td>
								<td>{{ gestion_etudiant.nom }}</td>
								<td>{{ gestion_etudiant.email }}</td>
								<td>{{ gestion_etudiant.age }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
		<div class="mt-5">
			<nav aria-label="Pagination">
				<ul class="pagination mb-0 justify-content-center">
					<li class="page-item">
						<a class="page-link" href="?page=1">
							&laquo; Page précédente
						</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=1">1</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=2">2</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=3">3</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=4">4</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=5">5</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=6">6</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=7">7</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=8">8</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=9">9</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=10">10</a>
					</li>
					<li class="page-item">
						<a class="page-link" href="?page=2">
							Page suivante &raquo;
						</a>
					</li>
				</ul>
			</nav>
		</div>
	</body>
</html>
