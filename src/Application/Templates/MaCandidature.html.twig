{% extends 'base.html.twig' %}

{% block title %}Ma Candidature-
{% endblock %}

{% block content %}

	<style>

		h2 {
			-webkit-text-stroke-width: 2px;
			-webkit-text-stroke-color: rgb(26, 189, 230);
		}
		.offre-card {
			background: rgba(255, 255, 255, 0.15);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, 0.3);
			border-radius: 15px;
		}
	</style>

	<main class="container py-5 text-center">
		<h2 class="text-center fw-bold mb-5 py-3">
			Voici vos candidature actuelles
		</h2>

		<div class="row g-4 justify-content-center">
			{% for candidature in candidatures %}
				<div class="col-md-4">
					<div class="offre-card p-4 text-white">
						<div class="fw-bold fs-5 mb-2">{{ candidature.nom }}</div>
						<div class="mb-2">{{ candidature.domaine }}</div>
						{% if role == 'pilote' or role == 'admin' %}
							<div>👤
								{{ candidature.utilisateur.prenom }}
								{{ candidature.utilisateur.nom }}</div>
							<div>📍
								{{ candidature.lieu }}</div>
							<div>✉️
								{{ candidature.email }}</div>
							<div>⏱️
								{{ candidature.duree }}
								| 💼{{ candidature.niveau }}
								| 💸{{ candidature.salaire }}</div>
							<div class="mt-2">{{ candidature.description }}</div>
						{% endif %}
						<div>Statut :
							{{ candidature.statut }}</div>
						{% if role == 'pilote' or role == 'admin' %}
							<form method="POST" action="{{ url_for('changer-statut', {'id': candidature.id, 'statut': 'accepte'}) }}" style="display:inline">
								<button class="btn btn-success btn-sm">Accepter</button>
							</form>
							<form method="POST" action="{{ url_for('changer-statut', {'id': candidature.id, 'statut': 'refuse'}) }}" style="display:inline">
								<button class="btn btn-danger btn-sm">Refuser</button>
							</form>
						{% endif %}
					</div>
				</div>
			{% endfor %}
		</div>
	</main>
{% endblock %}
