{% extends 'base2.html.twig' %}
{% block title %}Gestion des Entreprises
{% endblock %}
{% block heading %}Gestion des Entreprises
{% endblock %}
{% block content %}
	<form method="POST" action="{{ url_for('ajout-entreprises') }}" class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow-sm border border-secondary border-opacity-25">
		<div class="col-auto">
			<button type="submit" class="btn btn-add-custom px-4 fw-bold" id="add-student-btn">
				+
			</button>
		</div>
		<div class="col">
			<input type="text" name="nom" class="form-control form-control-dark" placeholder="Nom entreprise" required/>
		</div>
		<div class="col">
			<input type="text" name="domaine" class="form-control form-control-dark" placeholder="Domaine" required/>
		</div>
		<div class="col">
			<input type="text" name="lieu" class="form-control form-control-dark" placeholder="Lieux" required/>
		</div>
		<div class="col">
			<input type="email" name="email" class="form-control form-control-dark" placeholder="E-mail" required/>
		</div>
	</form>

	<div class="table-responsive rounded">
		<table class="table table-dark table-hover mb-0 table-custom">
			<thead>
				<tr>
					<th class="text-center">Actions</th>
					<th>ID</th>
					<th>Nom</th>
					<th>Domaine</th>
					<th>Lieux</th>
					<th>E-mail</th>
				</tr>
			</thead>
			<tbody id="table-body">
				{% for gestion_entreprise in gestion_entreprises %}
					<tr>
						<td class="text-center">
							<form method="POST" action="{{ url_for('supprimer-entreprises', { 'id': gestion_entreprise.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer cette entreprise ?')">
								<button type="submit" class="btn-delete">🗑️</button>
							</form>
							<a href="{{ url_for('modifier-entreprises', { 'id': gestion_entreprise.id }) }}" class="btn-edit">✏️</a>
						</td>
						<td>{{ gestion_entreprise.id }}</td>
						<td>{{ gestion_entreprise.nom }}</td>
						<td>{{ gestion_entreprise.domaine }}</td>
						<td>{{ gestion_entreprise.lieu }}</td>
						<td>{{ gestion_entreprise.email }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		{% if totalPages > 1 %}
			<nav class="mt-3">
				<ul class="pagination justify-content-center">

					<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_entreprises', {'page': page - 1}) }}">&laquo; Précédent</a>
					</li>

					{% for p in 1..totalPages %}
						<li class="page-item {% if p == page %}active{% endif %}">
							<a class="page-link" href="{{ url_for('gestion_entreprises', {'page': p}) }}">{{ p }}</a>
						</li>
					{% endfor %}

					<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_entreprises', {'page': page + 1}) }}">Suivant &raquo;</a>
					</li>
				</ul>
			</nav>
		{% endif %}
	</div>
{% endblock %}
