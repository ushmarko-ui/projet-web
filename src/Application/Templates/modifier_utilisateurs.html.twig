{% extends 'base2.html.twig' %}
{% block title %}Modifier un compte utilisateur
{% endblock %}
{% block heading %}Modifier un compte utilisateur
{% endblock %}

{% block content %}
	<div class="container mt-4 w-50">
		<form method="POST" action="{{ url_for('modifier-utilisateurs', {'id': gestion_utilisateurs.id}) }}">
			<div class="mb-3">
				<label class="form-label">Prenom</label>
				<input type="text" name="prenom" class="form-control form-control-dark" value="{{ gestion_utilisateurs.prenom }}" required/>
			</div>
			<div class="mb-3">
				<label class="form-label">Nom</label>
				<input type="text" name="nom" class="form-control form-control-dark" value="{{ gestion_utilisateurs.nom }}" required/>
			</div>
			<div class="mb-3">
				<label class="form-label">Mot de passe</label>
				<input type="text" name="mot_de_passe" class="form-control form-control-dark" value="{{ gestion_utilisateurs.motdepasse}}" required/>
			</div>
			<div class="mb-3">
				<label class="form-label">E-mail</label>
				<input type="email" name="email" class="form-control form-control-dark" value="{{ gestion_utilisateurs.email }}" required/>
			</div>
			<div class="mb-3">
				<label class="form-label">Lieu</label>
				<input type="text" name="lieu" class="form-control form-control-dark" value="{{ gestion_utilisateurs.lieu }}" required/>
			</div>
			<div class="mb-3">
				<label class="form-label">Role</label>
				<input type="text" name="role" class="form-control form-control-dark" value="{{ gestion_utilisateurs.role.value }}" required/>
			</div>
			<button type="submit" class="btn btn-primary">Sauvegarder</button>
			<a href="{{ url_for('gestion_utilisateurs') }}" class="btn btn-secondary">Annuler</a>
		</form>
	</div>
{% endblock %}
