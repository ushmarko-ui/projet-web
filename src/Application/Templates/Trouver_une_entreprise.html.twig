{% extends 'base.html.twig' %}

{% block title %}Entreprise-
{% endblock %}

{% block content %}
	<style>

		h2 {
			-webkit-text-stroke-width: 2px;
			-webkit-text-stroke-color: rgb(26, 189, 230);
		}
		.offre-card {
			background: rgba(255, 255, 255, 0.15);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, 0.3);
			border-radius: 15px;
		}
	</style>
	<main class="container py-5 text-center">
		<h2 class="text-center fw-bold mb-5 py-3">
			Trouver l'entreprise parfaite à vos besoins !
		</h2>

		<div class="row g-4 justify-content-center">
			{% for entreprise in entreprises %}
				<div class="col-md-4">
					<div class="offre-card p-4 text-white">
						<div class="fw-bold fs-5 mb-2">{{ entreprise.nom }}</div>
						<div class="mb-2">{{ entreprise.domaine }}</div>
						<div>📍
							{{ entreprise.lieu }}</div>
						<div>✉️
							{{ entreprise.email }}</div>
						<a href="{{ url_for('voir-avis', {'id': entreprise.id}) }}" class="btn btn-primary mt-2">Evaluer</a>
						<a href="{{ url_for('voir-offres', {'nom': entreprise.nom}) }}" class="btn btn-primary mt-2">Voir Offres</a>
					</div>
				</div>
			{% endfor %}
			{% if totalPages > 1 %}
				<nav class="mt-3">
					<ul class="pagination justify-content-center">

						<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
							<a class="page-link" href="{{ url_for('entreprise', {'page': page - 1}) }}">&laquo; Précédent</a>
						</li>

						{% for p in 1..totalPages %}
							<li class="page-item {% if p == page %}active{% endif %}">
								<a class="page-link" href="{{ url_for('entreprise', {'page': p}) }}">{{ p }}</a>
							</li>
						{% endfor %}

						<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
							<a class="page-link" href="{{ url_for('entreprise', {'page': page + 1}) }}">Suivant &raquo;</a>
						</li>

					</ul>
				</nav>
			{% endif %}
		</main>
	{% endblock %}
