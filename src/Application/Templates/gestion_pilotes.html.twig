{% extends 'base2.html.twig' %}
{% block title %}Gestion des Pilotes
{% endblock %}
{% block heading %}Gestion des Pilotes
{% endblock %}
{% block content %}
	<form method="POST" action="{{ url_for('ajout-pilotes') }}" class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow border border-secondary border-opacity-10">
		<div class="col-auto">
			<button class="btn btn-add-custom px-4 fw-bold shadow-sm" id="add-pilote-btn">
				+
			</button>
		</div>
		<div class="col">
			<input type="text" name="nom" id="pilote-last" class="form-control form-control-dark" placeholder="Nom Complet"/>
		</div>
		<div class="col-md">
			<input type="text" name="prenom" id="pilote-first" class="form-control form-control-dark" placeholder="Prenom"/>
		</div>
		<div class="col">
			<input type="text" name="mot_de_passe" id="pilote-first" class="form-control form-control-dark" placeholder="Mot de passe"/>
		</div>
		<div class="col">
			<input type="text" name="lieu" id="pilote-centre" class="form-control form-control-dark" placeholder="Ville"/>
		</div>
		<div class="col">
			<input type="email" name="email" id="pilote-email" class="form-control form-control-dark" placeholder="E-mail Professionnel"/>
		</div>
		<div class="col">
			<input type="texte" name="role" id="pilote-email" class="form-control form-control-dark" placeholder="Role"/>
		</div>
	</form>

	<div class="table-responsive rounded">
		<table class="table table-dark table-hover mb-0 table-custom">
			<thead>
				<tr>
					<th class="text-center">Actions</th>
					<th>ID</th>
					<th>Nom Complet</th>
					<th>Prenom</th>
					<th>Mot de passe</th>
					<th>Centre / Ville</th>
					<th>E-mail</th>
					<th>Role</th>
				</tr>
			</thead>
			<tbody id="pilote-table-body">
				{% for gestion_pilote in gestion_pilotes %}
					<tr>
						<td class="text-center">
							<form method="POST" action="{{ url_for('supprimer-pilotes', { 'id': gestion_pilote.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer ce compte pilote ?')">
								<button type="submit" class="btn-delete">🗑️</button>
							</form>
							<a href="{{ url_for('modifier-pilotes', { 'id': gestion_pilote.id }) }}" class="btn-edit">✏️</a>
						</td>
						<td>{{ gestion_pilote.id }}</td>
						<td>{{ gestion_pilote.nom}}</td>
						<td>{{ gestion_pilote.prenom}}</td>
						<td>{{ gestion_pilote.motdepasse}}</td>
						<td>{{ gestion_pilote.lieu}}</td>
						<td>{{ gestion_pilote.email }}</td>
						<td>{{ gestion_pilote.role }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		{% if totalPages > 1 %}
			<nav class="mt-3">
				<ul class="pagination justify-content-center">

					<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_pilotes', {'page': page - 1}) }}">&laquo; Précédent</a>
					</li>

					{% for p in 1..totalPages %}
						<li class="page-item {% if p == page %}active{% endif %}">
							<a class="page-link" href="{{ url_for('gestion_pilotes', {'page': p}) }}">{{ p }}</a>
						</li>
					{% endfor %}

					<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
						<a class="page-link" href="{{ url_for('gestion_pilotes', {'page': page + 1}) }}">Suivant &raquo;</a>
					</li>
				</ul>
			</nav>
		{% endif %}
	</div>
{% endblock %}
