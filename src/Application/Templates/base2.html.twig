<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>
			{% block title %}{% endblock %}
			- ReadyToWork</title>
		<link rel="icon" type="image/png" href="./image/ReadyToWork.png">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet"/>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		<style>
			body {
				font-family: "Poppins", sans-serif;
				background-color: #1a1a1a;
				color: white;
				padding: 30px;
			}
			h2 {
				font-weight: 600;
				margin-bottom: 30px;
				color: #72b1d5;
			}
			.form-control-dark {
				background-color: #121212 !important;
				border: 1px solid #333 !important;
				color: #ccc !important;
				font-size: 0.9rem;
			}
			.form-control-dark:focus {
				border-color: #72b1d5 !important;
				box-shadow: none;
			}
			.table-custom th {
				background-color: #2c2c2c !important;
				color: #888 !important;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 1px;
				border-bottom: 2px solid #333;
			}
			.table-custom td {
				color: #ccc;
				vertical-align: middle;
				border-bottom: 1px solid #333;
			}
			.btn-add-custom {
				background-color: #4a4a4a;
				color: white;
				border: none;
				transition: 0.3s;
			}
			.btn-add-custom:hover {
				background-color: #72b1d5;
				color: white;
			}
			.btn-delete,
			.btn-edit {
				background: none;
				border: none;
				transition: 0.3s;
				font-size: 20px;
				text-decoration: none;
			}
			.btn-delete:hover,
			.btn-edit:hover {
				opacity: 1;
				transform: scale(1.2);
			}
			.glass {
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 15px;
			}
			input::placeholder {
				color: white !important;
			}
		</style>
		{% block styles %}{% endblock %}
	</head>
	<body>
		<div class="container-fluid">
			<div class="d-flex justify-content-between align-items-center px-lg-5">
				<h2>
					{% block heading %}{% endblock %}
				</h2>
				<a href="{{ url_for('accueil') }}" class="glass d-inline-flex align-items-center p-2 px-3 text-decoration-none text-white mb-auto">
					<img src="/image/ReadyToWork.png" alt="Logo" height="35" class="me-2"/>
					<span class="fw-bold">ReadyToWork</span>
				</a>
			</div>

			{% block content %}{% endblock %}
		</div>
	</body>
</html>
