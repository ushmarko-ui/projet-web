{% extends 'base.html.twig' %}

{% block title %}Entreprise-
{% endblock %}

{% block content %}
	<style>

		h2 {
			-webkit-text-stroke-width: 2px;
			-webkit-text-stroke-color: rgb(26, 189, 230);
		}
		.offre-card {
			background: rgba(255, 255, 255, 0.15);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, 0.3);
			border-radius: 15px;
		}
	</style>
	<main class="container py-5 text-center">
		<h2 class="text-center fw-bold mb-5 py-3">
			Voici les offres de l'entreprises
		</h2>

		<div class="row g-4 justify-content-center">
			{% for VoirOffre in VoirOffres %}
				<div class="col-md-4">
					<div class="offre-card p-4 text-white">
						<div class="fw-bold fs-5 mb-2">{{ VoirOffre.nom }}</div>
						<div class="mb-2">{{ VoirOffre.domaine }}</div>
						<div>📍
							{{ VoirOffre.lieu }}</div>
						<div>✉️
							{{ VoirOffre.duree }}
							|  💼{{ VoirOffre.niveau }}
							|  💸{{ VoirOffre.salaire }}</div>
						<div>{{ VoirOffre.description }}</div>
						<a href="{{ url_for('postule', {'id': VoirOffre.id})}}" class="btn btn-primary mt-2">Postule</a>
						<form method="POST" action="{{ url_for('ajouter-souhait', {'id': VoirOffre.id}) }}" style="display:inline">
							<button type="submit" class="btn btn-primary mt-2">Enregistre</button>
						</form>
					</div>
				</div>
			{% endfor %}
			{% if totalPages > 1 %}
				<nav class="mt-3">
					<ul class="pagination justify-content-center">

						<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
							<a class="page-link" href="{{ url_for('entreprise', {'page': page - 1}) }}">&laquo; Précédent</a>
						</li>

						{% for p in 1..totalPages %}
							<li class="page-item {% if p == page %}active{% endif %}">
								<a class="page-link" href="{{ url_for('entreprise', {'page': p}) }}">{{ p }}</a>
							</li>
						{% endfor %}

						<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
							<a class="page-link" href="{{ url_for('entreprise', {'page': page + 1}) }}">Suivant &raquo;</a>
						</li>

					</ul>
				</nav>
			{% endif %}
		</main>
	{% endblock %}
