<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>
			ReadyToWork</title>
		<link rel="icon" type="image/png" href="./image/ReadyToWork.png">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet"/>

		<style>

			body {
				font-family: "Poppins", sans-serif;
				background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url("/image/background2.jpg") no-repeat center center fixed;
				background-size: cover;
				color: white;
				min-height: 100vh;
			}
			.hero-banner {
				height: 140px;
				background: url("/image/image_reunion.avif") center/cover;
				position: absolute;
				width: 100%;
				top: 0;
				z-index: -1;
				filter: brightness(0.6);
			}

			.glass {
				background: rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 15px;
			}
			.nav-link-custom {
				color: white;
				padding: 10px 20px;
				transition: 0.3s;
				border-radius: 10px;
				text-decoration: none;
			}

			.nav-link-custom:hover {
				background: rgba(119, 119, 119, 0.2);
				transform: translateY(-3px);
				color: #ffcc00;
			}
			.hover-warning:hover {
				color: #ffcc00 !important;
			}
		</style>
	</head>
	<body>
		<div class="hero-banner"></div>

		<header class="container-fluid py-3">
			<div class="d-flex justify-content-between align-items-center px-lg-5">
				<a href="/" class="glass d-flex align-items-center p-2 px-3 text-decoration-none text-white">
					<img src="./image/ReadyToWork.png" alt="Logo" height="35" class="me-2"/>
					<span class="fw-bold">ReadyToWork</span>
				</a>
				<a href="/role" class="glass d-flex align-items-center p-2 px-3 text-decoration-none text-white">
					<img src="image/image_reunion.avif" alt="Profil" class="rounded-circle me-2" width="30" height="30"/>
					<span>Mon Profil</span>
				</a>
			</div>
			<h1 class="text-center mt-5 fw-bold text-uppercase">
				ReadyToWork
			</h1>
		</header>

		<nav class="container-fluid px-lg-5">
			<hr class="border-2 opacity-50"/>
			<div class="d-flex flex-wrap justify-content-center gap-3 py-2">
				<a href="/stage" class="glass nav-link-custom">Stage</a>
				<a href="/entreprise" class="glass nav-link-custom">Entreprise</a>
				<a href="/souhait" class="glass nav-link-custom">Liste de souhaits</a>
				<a href="/gestion_etudiants" id="btn-ajout-etudiant" class="nav-link-custom bg-primary d-none">Gestion Étudiants</a>
				<a href="/creation_entreprise" id="btn-ajout-entreprise" class="nav-link-custom bg-warning d-none">Gestion Entreprise</a>
				<a href="/gestion_pilotes" id="btn-ajout-pilote" class="nav-link-custom bg-info d-none">Gestion Pilotes</a>
				<a href="/gestion_offres" id="btn-ajout-offres" class="nav-link-custom bg-dark d-none">Gestion Offres</a>
				<a href="/connexion" id="btn-login" class="glass nav-link-custom border-primary d-none">Se connecter</a>
				<a href="/deconnexion" id="btn-logout" class="nav-link-custom bg-danger d-none">Déconnexion</a>
			</div>
			<hr class="border-2 opacity-50"/>
		</nav>
		<form action="/postule/{{ id }}" method="POST" enctype="multipart/form-data">
			<div class="container glass mt-5 py-4 w-50 d-flex flex-column align-items-center">
				<div class="mb-3">
					<h1>Postule<h1></div>
						{% if success %}
							<div class="alert alert-success">{{ success }}</div>
						{% endif %}
						{% if error %}
							<div class="alert alert-danger">{{ error }}</div>
						{% endif %}

						<div class="mb-3 w-50">
							<label for="Prenom">Prenom</label>
							<input type="text" name="prenom" class="form-control" id="prenom" placeholder="Prenom" required>
						</div>
						<div class="mb-3 w-50">
							<label for="Nom">Nom</label>
							<input type="text" name="nom" class="form-control" id="nom" placeholder="Nom" required>
						</div>
						<div class="mb-3 w-50">
							<label for="telephone">Telephone</label>
							<input type="tel" name="telephone" class="form-control" id="telephone" placeholder="Telephone" required>
						</div>
						<div class="mb-3 w-50">
							<label for="email">Email address</label>
							<input type="email" name="email" class="form-control" id="email" placeholder="Entrer email" required>
						</div>
						<div class="mb-5 w-50">
							<label for="Description">Message</label>
							<textarea class="form-control" name="description" id="textarea" rows="5" placeholder="Message"></textarea>
						</div>
						<div class="mb-5">
							<label>fichier</label>
							<input type="file" id="fichier" name="fichier" accept=".pdf, .docx" required/>
							<input type="hidden" name="MAX_FILE_SIZE" value="2097152"/>
						</div>
						<button id="validation" value="submit" type="submit" class="btn btn-primary">Submit</button>
					</div>
				</form>
				<footer class="glass mt-5 py-4">
					<div class="container d-flex justify-content-center gap-4">
						<a href="/politique" class="text-white-50 text-decoration-none small hover-warning">Politique de confidentialité</a>
						<a href="/mentions" class="text-white-50 text-decoration-none small hover-warning">Mentions légales</a>
					</div>
					<div class="text-center">
						<p class="text-white-50 small mb-0">
							&copy; 2026 ReadyToWork. Tous droits réservés.
						</p>
					</div>
				</footer>
			</body>
		</html>
	</body>
</html>
