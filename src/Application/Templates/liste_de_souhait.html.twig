{% extends 'base.html.twig' %}

{% block title %}Souhait-
{% endblock %}

{% block content %}

	<style>

		.titre_souhait {
			text-align: center;
			margin-top: 50px;
			margin-bottom: 50px;
			font-size: 50px;
			font-weight: 800;
			color: white;
			-webkit-text-stroke-width: 2px;
			-webkit-text-stroke-color: rgb(26, 189, 230);
		}

		.tableau-container {
			background: rgba(0, 0, 0, 0.4);
			border-radius: 15px;
			padding: 20px;
			backdrop-filter: blur(5px);
		}

		.table-souhaits {
			border-collapse: collapse;
			width: 100%;
		}

		.table-souhaits th {
			padding-bottom: 15px;
			font-weight: bold;
			color: white;
			text-transform: uppercase;
			font-size: 0.9rem;
			text-align: center;
		}

		.table-souhaits td {
			border-top: 5px groove rgba(30, 171, 237, 0.721);
			border-bottom: 5px groove rgba(30, 171, 237, 0.721);
			min-width: 130px;
			text-align: center;
			padding: 20px;
			background: rgba(255, 255, 255, 0.05);
			transition: 0.3s;
		}

		.table-souhaits tr:hover td {
			background: rgba(30, 171, 237, 0.2);
			color: #ffcc00;
		}
		.btn-delete {
			background: none;
			border: none;
			opacity: 0.6;
			transition: 0.3s;
			font-size: 1.1rem;
		}

		.btn-delete:hover {
			opacity: 1;
			transform: scale(1.2);
		}
	</style>
</head>

<main class="container mb-5">
	<h1 class="titre_souhait">⭐ Voici votre liste de souhaits</h1>

	<div class="tableau-container table-responsive shadow-lg">
		<table class="table-souhaits">
			<thead>
				<tr>
					<th>Action</th>
					<th>Nom entreprise</th>
					<th>Ville</th>
					<th>Date du stage</th>
					<th>Domaine</th>
					<th>Description</th>
					<th>Adresse Mail</th>
				</tr>
			</thead>
			{% for souhait in souhaits %}
				<tbody>
					<tr>
						<td class="text-center">
							<form method="POST" action="{{ url_for('supprimer-souhait', { 'id': souhait.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer ce souhait ?')">
								<button type="submit" class="btn-delete">🗑️</button>
							</form>
						</td>
						<td>{{ souhait.Nom }}</td>
						<td>{{ souhait.Lieu }}</td>
						<td>{{ souhait.Duree}}</td>
						<td>{{ souhait.Domaine }}</td>
						<td>{{ souhait.Description }}</td>
						<td>{{ souhait.Email }}</td>
					</tr>
				</tbody>
			{% endfor %}
		</table>
	</div>
	{% if totalPages > 1 %}
		<nav class="mt-3">
			<ul class="pagination justify-content-center">

				<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
					<a class="page-link" href="{{ url_for('souhait', {'page': page - 1}) }}">&laquo; Précédent</a>
				</li>

				{% for p in 1..totalPages %}
					<li class="page-item {% if p == page %}active{% endif %}">
						<a class="page-link" href="{{ url_for('souhait', {'page': p}) }}">{{ p }}</a>
					</li>
				{% endfor %}

				<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
					<a class="page-link" href="{{ url_for('souhait', {'page': page + 1}) }}">Suivant &raquo;</a>
				</li>

			</ul>
		</nav>
	{% endif %}
</main>{% endblock %}
