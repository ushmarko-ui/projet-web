{% extends 'base.html.twig' %}

{% block title %}Souhait-
{% endblock %}

{% block content %}

	<style>

		.titre_souhait {
			text-align: center;
			margin-top: 50px;
			margin-bottom: 50px;
			font-size: 50px;
			font-weight: 800;
			color: white;
			-webkit-text-stroke-width: 2px;
			-webkit-text-stroke-color: rgb(26, 189, 230);
		}

		.tableau-container {
			background: rgba(0, 0, 0, 0.4);
			border-radius: 15px;
			padding: 20px;
			backdrop-filter: blur(5px);
		}

		.table-souhaits {
			border-collapse: collapse;
			width: 100%;
		}

		.table-souhaits th {
			padding-bottom: 15px;
			font-weight: bold;
			color: white;
			text-transform: uppercase;
			font-size: 0.9rem;
			text-align: center;
		}

		.table-souhaits td {
			border-top: 5px groove rgba(30, 171, 237, 0.721);
			border-bottom: 5px groove rgba(30, 171, 237, 0.721);
			min-width: 130px;
			text-align: center;
			padding: 20px;
			background: rgba(255, 255, 255, 0.05);
			transition: 0.3s;
		}

		.table-souhaits tr:hover td {
			background: rgba(30, 171, 237, 0.2);
			color: #ffcc00;
		}
		.btn-delete {
			background: none;
			border: none;
			opacity: 0.6;
			transition: 0.3s;
			font-size: 1.1rem;
		}

		.btn-delete:hover {
			opacity: 1;
			transform: scale(1.2);
		}
	</style>
</head>

<main class="container mb-5">
	<h1 class="titre_souhait">⭐ Voici votre liste de souhaits</h1>

	<div class="tableau-container table-responsive shadow-lg">
		<table class="table-souhaits">
			<thead>
				<tr>
					<th>Action</th>
					<th>Nom entreprise</th>
					<th>Ville</th>
					<th>Date du stage</th>
					<th>Domaine</th>
					<th>Niveau d'étude</th>
					<th>Salaire</th>
				</tr>
			</thead>
			{% for souhait in souhaits %}
				<tbody>
					<tr>
						<td class="text-center">
							<button class="btn-delete btn-supprimer">🗑️</button>
						</td>
						<td>{{ souhait.Nom }}</td>
						<td>{{ souhait.Ville }}</td>
						<td>{{ souhait.Date}}</td>
						<td>{{ souhait.Domaine }}</td>
						<td>{{ souhait.Niveau }}</td>
						<td>{{ souhait.Salaire }}</td>
					</tr>
				</tbody>
			{% endfor %}
		</table>
	</div>
	<div class="mt-5">
		<nav aria-label="Pagination">
			<ul class="pagination mb-0 justify-content-center">
				<li class="page-item">
					<a class="page-link" href="?page=1">
						&laquo; Page précédente
					</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=1">1</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=2">2</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=3">3</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=4">4</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=5">5</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=6">6</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=7">7</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=8">8</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=9">9</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=10">10</a>
				</li>
				<li class="page-item">
					<a class="page-link" href="?page=2">
						Page suivante &raquo;
					</a>
				</li>
			</ul>
		</nav>
	</div>
</main>{% endblock %}
