{% extends 'base2.html.twig' %}
{% block title %}Gestion des Etudiants
{% endblock %}
{% block heading %}Gestion des Utilisateurs
{% endblock %}
{% block content %}

	<form method="POST" action="{{ url_for('ajout-utilisateurs') }}" class="row g-2 mb-4 align-items-center bg-dark p-3 rounded shadow-sm border border-secondary border-opacity-25">
		<div class="col-auto">
			<button type="submit" class="btn btn-add-custom px-4 fw-bold">+</button>
		</div>
		<div class="col">
			<input type="text" name="prenom" class="form-control form-control-dark" placeholder="Prénom" required/>
		</div>
		<div class="col">
			<input type="text" name="nom" class="form-control form-control-dark" placeholder="Nom" required/>
		</div>
		<div class="col">
			<input type="text" name="mot_de_passe" class="form-control form-control-dark" placeholder="Mot de passe" required/>
		</div>
		<div class="col">
			<input type="text" name="campus" class="form-control form-control-dark" placeholder="Lieu" required/>
		</div>
		<div class="col">
			<input type="email" name="email" class="form-control form-control-dark" placeholder="E-mail" required/>
		</div>
		<div class="col">
			<input type="text" name="role" class="form-control form-control-dark" placeholder="Role" required/>
		</div>
	</form>

	<div class="table-responsive rounded">
		<table class="table table-dark table-hover mb-0 table-custom">
			<thead>
				<tr>
					<th class="text-center">Actions</th>
					<th>ID</th>
					<th>Prénom</th>
					<th>Nom</th>
					<th>Mot de passe</th>
					<th>Lieu</th>
					<th>E-mail</th>
					<th>Role</th>
				</tr>
			</thead>
			<tbody>
				{% for gestion_utilisateur in gestion_utilisateurs %}
					<tr>
						<td class="text-center">
							<form method="POST" action="{{ url_for('supprimer-utilisateurs', { 'id': gestion_utilisateur.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer ce compte étudiant ?')">
								<button type="submit" class="btn-delete">🗑️</button>
							</form>
							<a href="{{ url_for('modifier-utilisateurs', { 'id': gestion_utilisateur.id }) }}" class="btn-edit">✏️</a>
						</td>
						<td>{{ gestion_utilisateur.id }}</td>
						<td>{{ gestion_utilisateur.prenom }}</td>
						<td>{{ gestion_utilisateur.nom }}</td>
						<td>{{ gestion_utilisateur.motdepasse }}</td>
						<td>{{ gestion_utilisateur.campus }}</td>
						<td>{{ gestion_utilisateur.email }}</td>
						<td>{{ gestion_utilisateur.role.value }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</tbody>
	</table>
	{% if totalPages > 1 %}
		<nav class="mt-3">
			<ul class="pagination justify-content-center">

				<li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
					<a class="page-link" href="{{ url_for('gestion_etudiants', {'page': page - 1}) }}">&laquo; Précédent</a>
				</li>

				{% for p in 1..totalPages %}
					<li class="page-item {% if p == page %}active{% endif %}">
						<a class="page-link" href="{{ url_for('gestion_etudiants', {'page': p}) }}">{{ p }}</a>
					</li>
				{% endfor %}

				<li class="page-item {{ page >= totalPages ? 'disabled' : '' }}">
					<a class="page-link" href="{{ url_for('gestion_etudiants', {'page': page + 1}) }}">Suivant &raquo;</a>
				</li>
			</ul>
		</nav>
	{% endif %}
</div>{% endblock %}
